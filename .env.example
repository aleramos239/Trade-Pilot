# Required in production.
DATABASE_URL="postgres://user:password@host:5432/trade_copilot"
CREDENTIAL_ENCRYPTION_KEY="base64-encoded-32-byte-key"

# Set to true only when your Postgres provider requires SSL without local CA validation.
DATABASE_SSL="false"

# Local diagnostics only. Do not set in production unless you intentionally want .data fallback.
ALLOW_JSON_STORE_IN_PRODUCTION="false"

# Required for scheduled reconciliation on Vercel.
CRON_SECRET="replace-with-a-long-random-secret"

# Required for Tradecopia-style Tradovate broker login.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
TRADOVATE_OAUTH_CLIENT_ID=""
TRADOVATE_OAUTH_CLIENT_SECRET=""
TRADOVATE_OAUTH_REDIRECT_URI="http://localhost:3000/api/broker-connections/oauth/tradovate/callback"

# Production operator login. Generate with: npm.cmd run auth:hash -- <password>
OPERATOR_PASSWORD_HASH="salt:hash"
ALLOW_DEMO_LOGIN="false"

# Optional bridge URLs are stored per broker connection in the UI.
